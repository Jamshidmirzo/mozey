# Database
DATABASE_URL=postgresql://muzeylari:muzeylari_secret@localhost:5432/muzeylari?schema=public

# JWT — App (device auth)
APP_JWT_SECRET=change-me-app-jwt-secret-min-32-chars
APP_JWT_EXPIRES_IN=365d

# JWT — Admin
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-min-32-chars
ADMIN_JWT_EXPIRES_IN=15m
ADMIN_JWT_REFRESH_SECRET=change-me-admin-refresh-secret-min-32-chars
ADMIN_JWT_REFRESH_EXPIRES_IN=7d

# S3-Compatible Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=muzeylari
S3_PUBLIC_URL=http://localhost:9000/muzeylari

# Application
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Admin seed
ADMIN_SEED_EMAIL=admin@muzeylari.uz
ADMIN_SEED_PASSWORD=change-me-admin-password
